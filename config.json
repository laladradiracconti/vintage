  "recensioni_attive": "SI",
  "recensioni_titolo": "Cose dette in negozio",
  "recensione_principale_testo": "Ci entro per guardare e finisco sempre con un pezzo che sembra aspettasse me.",
  "recensione_principale_nome": "Elena",
  "recensione_1_attiva": "SI",
  "recensione_1_nome": "Giulia R.",
  "recensione_1_testo": "Ho trovato una giacca anni 80 in condizioni perfette. Misure chiare e consigli onesti.",
  "recensione_1_stelle": "5",
  "recensione_2_attiva": "SI",
  "recensione_2_nome": "Tommaso L.",
  "recensione_2_testo": "Bella selezione di vinili, niente scatoloni confusi. Si vede che ogni pezzo e scelto.",
  "recensione_2_stelle": "5",
  "recensione_3_attiva": "SI",
  "recensione_3_nome": "Chiara M.",
  "recensione_3_testo": "Piccola bottega curata, prezzi leggibili e oggetti con carattere. Torno spesso.",
  "recensione_3_stelle": "5",
  "recensione_4_attiva": "SI",
  "recensione_4_nome": "Andrea P.",
  "recensione_4_testo": "Mi hanno aiutato a scegliere una lampada per casa senza spingere sulla vendita.",
  "recensione_4_stelle": "5",
  "recensione_5_attiva": "SI",
  "recensione_5_nome": "Sara F.",
  "recensione_5_testo": "Abiti puliti, ben esposti e facili da provare. Atmosfera tranquilla.",
  "recensione_5_stelle": "5",
  "recensione_6_attiva": "SI",
  "recensione_6_nome": "Nico B.",
  "recensione_6_testo": "Ottimo posto per regali diversi dal solito, con pezzi gia pronti da portare via.",
  "recensione_6_stelle": "5",
